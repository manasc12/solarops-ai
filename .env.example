# ── Chroma (vector database for local development using docker) ───────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
# ──────────── Chroma Cloud (vector database) ──────────────────────────────────────────────────────────
CHROMA_API_KEY=your-chroma-cloud-api-key
CHROMA_TENANT=your-chroma-cloud-tenant-id
CHROMA_DATABASE=your-chroma-cloud-database-name

# ── Application ────────────────────────────────────────────────
APP_NAME=SolarOps AI
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ── Backend / Frontend wiring ──────────────────────────────────
BACKEND_URL=http://localhost:8000

# ── External data sources ──────────────────────────────────────
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/daily/point
WEATHER_USE_MOCK=true

# ── LLM (optional — deterministic fallback used if unset) ───────
OPENAI_API_KEY= your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
LLM_USE_MOCK=true

# ── ML ─────────────────────────────────────────────────────────
MODEL_DIR=data/processed/models
ANOMALY_THRESHOLD=0.6

# ── RAG ────────────────────────────────────────────────────────
RAG_DOCS_DIR=rag/data/manuals
RAG_INDEX_DIR=data/processed/rag_index
RAG_TOP_K=4
RAG_COLLECTION_NAME=solarops_docs
RAG_EMBEDDING_MODEL=text-embedding-3-small
CHUNK_SIZE=600
CHUNK_OVERLAP=100